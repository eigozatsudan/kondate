# リモートリポジトリへの変更送信は外部状態を更新するため、毎回ユーザーの明示的な承認を必要とする。
prefix_rule(
    pattern = ["git", "push"],
    decision = "prompt",
    justification = "git push はリモートリポジトリを更新するため、実行前にユーザー承認が必要です",
    match = [
        "git push",
        "git push origin main",
    ],
    not_match = [
        "git pull",
        "git status",
    ],
)
