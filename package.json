{
  "name": "kondate",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "format": "find . -path './.git' -prune -o -path './node_modules' -prune -o -path './.netlify' -prune -o -path './infra/supabase/volumes' -prune -o -type f \\( -name '*.js' -o -name '*.mjs' -o -name '*.ts' -o -name '*.tsx' -o -name '*.json' -o -name '*.css' -o -name '*.md' -o -name '*.yml' -o -name '*.yaml' \\) -print0 | xargs -0 prettier --write",
    "format:check": "find . -path './.git' -prune -o -path './node_modules' -prune -o -path './.netlify' -prune -o -path './infra/supabase/volumes' -prune -o -type f \\( -name '*.js' -o -name '*.mjs' -o -name '*.ts' -o -name '*.tsx' -o -name '*.json' -o -name '*.css' -o -name '*.md' -o -name '*.yml' -o -name '*.yaml' \\) -print0 | xargs -0 prettier --check",
    "lint": "NODE_OPTIONS=--max-old-space-size=4096 eslint .",
    "typecheck": "tsc -b",
    "test": "vitest",
    "db:push": "docker compose run --rm migrate",
    "db:reset": "./scripts/reset-local-db.sh",
    "db:test": "docker compose run --rm db-test",
    "db:types": "bash scripts/generate-database-types.sh",
    "e2e": "playwright test",
    "verify:openrouter:config": "node scripts/verify-openrouter-models.mjs",
    "verify:openrouter:models": "node scripts/verify-openrouter-models.mjs --remote",
    "predev": "npm run verify:openrouter:config",
    "prebuild": "npm run verify:openrouter:config",
    "test:openrouter:smoke": "vitest run netlify/functions/_shared/openrouter.smoke.test.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.57.0",
    "@tanstack/react-query": "^5.87.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.62.0",
    "react-router": "^8.0.0",
    "zod": "^4.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@netlify/functions": "^5.3.0",
    "@netlify/vite-plugin": "^2.5.0",
    "@playwright/test": "^1.55.0",
    "@tailwindcss/vite": "^4.1.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.35.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "jsdom": "^27.0.0",
    "netlify-cli": "26.2.0",
    "prettier": "^3.6.0",
    "supabase": "^2.50.0",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.42.0",
    "vite": "^8.0.0",
    "vitest": "^4.0.0"
  }
}
